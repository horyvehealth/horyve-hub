{
  "compilerOptions": {
    "target": "ES2017",
    "module": "none",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "./",
    "rootDir": "./",
    "removeComments": false,
    "sourceMap": false,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["main.ts"],
  "exclude": ["node_modules"]
}
